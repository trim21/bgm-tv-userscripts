{
  "name": "bgm-wiki-rev-diff",
  "description": "Build your UserScript with webpack",
  "version": "0.0.4",
  "private": true,
  "license": "MIT",
  "prettier": {
    "printWidth": 120,
    "trailingComma": "all",
    "singleQuote": true,
    "endOfLine": "lf",
    "semi": true
  },
  "scripts": {
    "bump": "node bump.js",
    "tsc": "tsc --noEmit",
    "lint": "eslint --ext cjs,js,ts,mjs ./",
    "format": "prettier --list-different  -w .",
    "format:check": "prettier --check .",
    "test": "jest",
    "build": "webpack -c scripts/*/config/webpack.config.prod.js -c scripts/*/config/webpack.config.prod.mjs",
    "lint-staged": "lint-staged"
  },
  "author": {
    "name": "Trim21",
    "email": "i@trim21.me"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/trim21/bgm-tv-userscripts"
  },
  "lint-staged": {
    "*.{cjs,js,mjs,ts,json,yml,yaml}": "prettier --write",
    "*.{cjs,js,mjs,ts}": "eslint --fix"
  },
  "dependencies": {
    "diff": "9.0.0",
    "diff2html": "3.4.56",
    "jquery": "4.0.0",
    "lodash": "4.18.1",
    "lodash-es": "4.18.1"
  },
  "browserslist": [
    "chrome >= 102",
    "last 10 Edge version",
    "last 2 Safari Major version",
    "last 10 Firefox version"
  ],
  "devDependencies": {
    "@actions/exec": "3.0.0",
    "@jest/globals": "30.3.0",
    "@types/greasemonkey": "4.0.7",
    "@types/hogan.js": "3.0.5",
    "@types/jquery": "4.0.0",
    "@types/lodash": "4.17.24",
    "@types/lodash-es": "4.17.12",
    "@types/node": "24.12.2",
    "@typescript-eslint/eslint-plugin": "8.59.1",
    "@typescript-eslint/parser": "8.59.1",
    "esbuild-loader": "4.4.3",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-promise": "7.3.0",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "lint-staged": "16.4.0",
    "prettier": "3.8.3",
    "raw-loader": "4.0.2",
    "semver": "7.7.4",
    "ts-jest": "29.4.9",
    "typescript": "6.0.3",
    "userscript-metadata-webpack-plugin": "0.4.2",
    "webpack": "5.106.2",
    "webpack-cli": "7.0.2",
    "webpack-livereload-plugin": "3.0.2",
    "webpack-merge": "6.0.1",
    "yargs": "18.0.0"
  },
  "packageManager": "yarn@4.14.1"
}
